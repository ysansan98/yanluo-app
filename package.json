{
  "name": "yanluo-app",
  "version": "1.0.0",
  "description": "An Electron application with Vue and TypeScript",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:debug": "electron-vite dev -- --remote-debugging-port=9222",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build": "pnpm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && pnpm run rebuild:native",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux",
    "python:prepare": "node build/prepare-python.js",
    "python:clean": "node build/clean-python.js",
    "python:verify": "node build/verify-package.js",
    "build:full": "pnpm run python:prepare && pnpm run build && electron-builder",
    "build:full:verify": "pnpm run build:full && pnpm run python:verify",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "pnpm run build && playwright test",
    "test:all": "pnpm run test:unit && pnpm run test:e2e"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.6.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "node-global-key-listener": "^0.3.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "code-inspector-plugin": "^1.4.2",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.6.2",
    "playwright": "^1.58.2",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.18",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
