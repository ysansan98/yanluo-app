{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "~shared/*": ["src/shared/*"]
    },
    "types": ["vitest/globals", "node", "electron-vite/node"]
  },
  "include": [
    "tests/**/*",
    "src/preload/*.d.ts",
    "src/renderer/src/env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "build",
    "resources"
  ]
}
